# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local for local development.
# For production (Vercel), set these in the Vercel dashboard under
# Project Settings → Environment Variables.

# ─── Public URLs (exposed to browser bundle) ─────────────────────────────────
# The full URL of this Next.js frontend
NEXT_PUBLIC_APP_URL=http://localhost:5180

# The FastAPI backend REST API base URL
NEXT_PUBLIC_API_URL=http://localhost:8030

# The FastAPI backend WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8030

# ─── Better Auth (server-only) ───────────────────────────────────────────────
# PostgreSQL connection string — same DB as the backend
DATABASE_URL=postgresql://latexy_user:password@localhost:5432/latexy

# Must match NEXT_PUBLIC_APP_URL exactly (used by Better Auth for CSRF/CORS)
BETTER_AUTH_URL=http://localhost:5180

# Strong random secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-development

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
# Leave blank to disable Google/GitHub sign-in buttons
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Misc ────────────────────────────────────────────────────────────────────
# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
