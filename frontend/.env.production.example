# ─── Frontend Production Environment Variables ───────────────────────────────
# These go into Vercel dashboard → Project Settings → Environment Variables.
# Set scope to "Production" (and optionally "Preview") for each variable.
#
# ⚠️  Never commit actual secrets to git — this file contains only templates.

# ─── Public URLs (exposed to browser bundle) ─────────────────────────────────
# Your Vercel deployment URL or custom domain
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Your deployed FastAPI backend URL (Railway / Render / Fly.io / VPS)
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# WebSocket URL — same host as API, ws:// or wss://
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com

# ─── Better Auth (server-only, never exposed to browser) ─────────────────────
# Neon / Supabase / Railway Postgres connection string
DATABASE_URL=postgresql://user:password@host:5432/latexy_prod

# Must match NEXT_PUBLIC_APP_URL exactly
BETTER_AUTH_URL=https://your-app.vercel.app

# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-strong-random-secret

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Misc ────────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
