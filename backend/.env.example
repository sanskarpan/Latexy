# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Latexy-Backend
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8030
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# Full async PostgreSQL URL (required). Use asyncpg driver:
# Required by docker-compose.yml — DATABASE_URL must be set explicitly (no default).
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@localhost:5432/latexy
# Alternative: individual fields (used if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# Required by docker-compose.yml — DB_PASSWORD must be set explicitly (no default).
DB_PASSWORD=change-me-strong-password
DB_NAME=latexy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Auth (Better Auth + JWT fallback) ─────────────────────────────────────────
# Required: Better Auth secret used by the frontend Next.js service
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
# URL of the frontend service (for Better Auth cross-origin validation)
BETTER_AUTH_URL=http://localhost:5180
# Legacy JWT secret (for existing tokens during migration)
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── OpenAI (required for LLM optimization and embeddings) ─────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# ── Multi-Provider LLM (optional BYOK providers) ──────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── BYOK Encryption ───────────────────────────────────────────────────────────
# Required if BYOK feature is enabled. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=

# ── LaTeX ─────────────────────────────────────────────────────────────────────
LATEX_DOCKER_IMAGE=texlive/texlive:latest
COMPILE_TIMEOUT=30
MAX_FILE_SIZE=10485760

# ── File Storage ──────────────────────────────────────────────────────────────
PDF_RETENTION_TIME=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (include your frontend URL)
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://localhost:3000

# ── OAuth (optional social login) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Job / Queue Settings ──────────────────────────────────────────────────────
JOB_RESULT_TTL=86400
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=60

# ── Test Users ────────────────────────────────────────────────────────────────
# Comma-separated emails that get elevated trial quota (TEST_TRIAL_LIMIT) instead of TRIAL_LIMIT
TEST_USER_EMAILS=

# ── Email Notifications (Feature 19) ──────────────────────────────────────────
# Master toggle — set to true only after configuring a provider below
EMAIL_ENABLED=false
# Provider: "resend" or "smtp"
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@latexy.io
EMAIL_FROM_NAME=Latexy

# Resend (https://resend.com — 3k free emails/month)
RESEND_API_KEY=

# SMTP (alternative — works with Gmail, Brevo, AWS SES, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Production Docker Compose Variables ───────────────────────────────────────
# Only needed when running docker-compose.prod.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=latexy
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flower-password
GRAFANA_PASSWORD=change-me-grafana-password
